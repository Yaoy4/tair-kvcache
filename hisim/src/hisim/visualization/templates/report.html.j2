<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>{{ title }}</title>
<style>
  body { font-family: -apple-system, "Segoe UI", Roboto, sans-serif; margin: 24px; color: #222; }
  h1 { margin: 0 0 4px 0; }
  .meta { color: #666; font-size: 13px; margin-bottom: 24px; }
  .section { margin-bottom: 32px; }
  .section h2 { border-bottom: 1px solid #ddd; padding-bottom: 4px; }
  table.summary { border-collapse: collapse; font-size: 13px; }
  table.summary th, table.summary td { border: 1px solid #ddd; padding: 4px 10px; text-align: left; }
  table.summary th { background: #f5f5f5; }
  .figure { margin: 12px 0; }
</style>
</head>
<body>
<h1>{{ title }}</h1>
<div class="meta">
  Generated {{ generated_at }} &middot; {{ n_rows }} configurations &middot;
  {{ n_pareto }} on Pareto frontier
</div>

<div class="section">
  <h2>Overview</h2>
  <table class="summary">
    <tr><th>Configurations</th><td>{{ n_rows }}</td></tr>
    <tr><th>Pareto-optimal</th><td>{{ n_pareto }}</td></tr>
    <tr><th>Disagg rows</th><td>{{ n_disagg }}</td></tr>
    <tr><th>Aggregated rows</th><td>{{ n_agg }}</td></tr>
    <tr><th>Source CSV</th><td>{{ source }}</td></tr>
  </table>
</div>

{% for section in sections %}
<div class="section">
  <h2>{{ section.title }}</h2>
  <div class="figure">{{ section.html | safe }}</div>
</div>
{% endfor %}

</body>
</html>
